<div class="bg-surface font-body-md text-on-surface antialiased min-h-screen">
  <!-- Header -->
  <div class="sticky top-0 z-50 bg-white border-b border-gray-200">
    <div class="flex items-center justify-between px-6 h-16">
      <div class="flex items-center gap-3">
        <button
          type="button"
          class="p-2 rounded-full hover:bg-gray-100 transition"
        >
          <span class="material-symbols-outlined">arrow_back</span>
        </button>

        <.header>
          {@title}
        </.header>
      </div>

      <button
        type="submit"
        form="apartment-form"
        class="text-sm font-semibold text-black hover:bg-gray-100 px-4 py-2 rounded-lg transition"
      >
        Save
      </button>
    </div>
  </div>

  <!-- Main -->
  <div class="max-w-5xl mx-auto px-6 pt-8 pb-32">
    <.simple_form
      for={@form}
      id="apartment-form"
      phx-target={@myself}
      phx-change="validate"
      phx-submit="save"
    >
      <!-- Apartment Information -->
      <div class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-sm font-semibold text-gray-500">
              Apartment Name
            </label>

            <.input
              field={@form[:name]}
              placeholder="e.g Skyline Heights"
              class="w-full rounded-xl border-gray-300 bg-white focus:ring-2 focus:ring-black"
            />
          </div>

          <div class="space-y-2">
            <label class="text-sm font-semibold text-gray-500">
              Location
            </label>

            <div class="relative">
             

              <.input
                field={@form[:location]}
                placeholder="123 Main St, Springfield"
                class="pl-10 w-full rounded-xl border-gray-300 bg-white focus:ring-2 focus:ring-black"
              />
            </div>
          </div>
        </div>

        <!-- Banner -->
        <div class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 aspect-[21/9]">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCJBxOtK7obG2uxDJK3Kr2BoIyOFZQvE9yqbqDHLLPDVxknclMqDWjzR4Mk5QrU5VBKceG027XkgsFw1YwHg1RiKZpsw1FstRpwew2g0sSers_UdZqKv17zulZe0eg8itnqHcH9YsKsTg6wk3lK5iUA12sTemag3haJSer3znqxB_x0TI1UZ_bMmic05Edpq__iU1ZgoxFKSUYzEb7skAoO_3lyV6PhtSxDzJIkz2zZuNkOzmgFgP3tXiBEQHv-A42J5Ayei4uYL52l"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Floors -->
        <div class="space-y-6">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-bold text-gray-900">
              Floors
            </h3>

            <button
              type="button"
              phx-click="add-floor"
              phx-target={@myself}
              class="flex items-center gap-2 bg-black text-white px-4 py-2 rounded-xl text-sm font-medium hover:opacity-90 transition"
            >
              <span class="material-symbols-outlined text-[18px]">add</span>
              Add Floor
            </button>
          </div>

          <!-- Floors -->
          <.inputs_for :let={f_form} field={@form[:floors]}>
            <div class="bg-white border border-gray-200 rounded-2xl p-6 relative shadow-sm space-y-6">
              <!-- Remove Floor -->
              <button
                type="button"
                phx-click="remove-floor"
                phx-target={@myself}
                phx-value-index={f_form.index}
                class="absolute top-4 right-4 text-gray-400 hover:text-red-500 transition"
              >
                <span class="material-symbols-outlined">close</span>
              </button>

              <input
                type="hidden"
                name={f_form[:id].name}
                value={f_form[:id].value}
              />

              <!-- Floor Name -->
              <div class="space-y-2">
                <label class="text-xs uppercase tracking-widest text-gray-500 font-semibold">
                  Floor Name
                </label>

                <.input
                  field={f_form[:name]}
                  type="text"
                  placeholder="Ground Floor"
                  class="border-0 border-b border-gray-200 rounded-none px-0 text-lg font-semibold focus:ring-0 focus:border-black bg-transparent"
                />
              </div>

              <div class="border-t border-gray-200"></div>

              <!-- Units -->
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <h4 class="text-sm font-bold uppercase tracking-wider text-gray-500">
                    Units
                  </h4>

                  <button
                    type="button"
                    phx-click="add-unit"
                    phx-target={@myself}
                    phx-value-floor-index={f_form.index}
                    class="flex items-center gap-1 text-sm font-medium text-black hover:underline"
                  >
                    <%!-- <span class="material-symbols-outlined text-[16px]">
                      add_circle
                    </span> --%>

                    Add Unit
                  </button>
                </div>

                <!-- Empty State -->
                <%= if Enum.empty?(f_form[:units].value || []) do %>
                  <div class="border-2 border-dashed border-gray-300 rounded-2xl p-10 flex flex-col items-center justify-center text-center gap-3">
                    <span class="material-symbols-outlined text-5xl text-gray-400">
                      domain
                    </span>

                    <p class="text-gray-500">
                      No units added to this floor
                    </p>

                    <button
                      type="button"
                      phx-click="add-unit"
                      phx-target={@myself}
                      phx-value-floor-index={f_form.index}
                      class="px-4 py-2 border border-black rounded-xl text-sm font-medium hover:bg-gray-100 transition"
                    >
                      + Add First Unit
                    </button>
                  </div>
                <% end %>

                <!-- Units Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <.inputs_for :let={r_form} field={f_form[:units]}>
                    <div class="relative bg-gray-50 border border-gray-200 rounded-xl p-4 space-y-4">
                      <!-- Remove Unit -->
                      <button
                        type="button"
                        phx-click="remove-unit"
                        phx-target={@myself}
                        phx-value-floor-index={f_form.index}
                        phx-value-unit-index={r_form.index}
                        class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition"
                      >
                        <span class="material-symbols-outlined text-[18px]">
                          close
                        </span>
                      </button>

                      <input
                        type="hidden"
                        name={r_form[:id].name}
                        value={r_form[:id].value}
                      />

                      <!-- Unit Name + Price -->
                      <div class="grid grid-cols-2 gap-3">
                        <div class="space-y-1">
                          <label class="text-xs font-semibold text-gray-500">
                            Unit Name
                          </label>

                          <.input
                            field={r_form[:name]}
                            placeholder="G-01"
                            class="rounded-lg border-gray-300 bg-white"
                          />
                        </div>

                        <div class="space-y-1">
                          <label class="text-xs font-semibold text-gray-500">
                            Monthly Price
                          </label>

                          <.input
                            field={r_form[:price]}
                            type="number"
                            placeholder="1200"
                            class="rounded-lg border-gray-300 bg-white"
                          />
                        </div>
                      </div>

                      <!-- Description -->
                      <div class="space-y-1">
                        <label class="text-xs font-semibold text-gray-500">
                          Description
                        </label>

                        <.input
                          field={r_form[:description]}
                          type="text"
                          placeholder="Studio with garden access"
                          class="rounded-lg border-gray-300 bg-white"
                        />
                      </div>

                      <!-- Booking -->
                      <div class="space-y-1">
                        <label class="text-xs font-semibold text-gray-500">
                          Booking Status
                        </label>

                        <.input
                          field={r_form[:booking]}
                          type="text"
                          value={"none"}
                          placeholder="booking status"
                          class="rounded-lg border-gray-300 bg-white"
                        />
                      </div>
                    </div>
                  </.inputs_for>
                </div>
              </div>
            </div>
          </.inputs_for>
        </div>
      </div>

      <!-- Sticky Footer -->
      <:actions>
        <div class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-200 px-6 py-4 z-40">
          <div class="max-w-5xl mx-auto">
            <.button
              phx-disable-with="Saving..."
              class="w-full bg-black hover:bg-gray-900 text-white rounded-xl py-4 text-sm font-semibold shadow-lg"
            >
              Save Apartment Complex
            </.button>
          </div>
        </div>
      </:actions>
    </.simple_form>
  </div>
</div>